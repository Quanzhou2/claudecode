# ------------------------------------------------------------------
# Expense Reimbursement System — environment configuration
# Copy to `.env` and adjust. All values have sensible defaults.
# ------------------------------------------------------------------

# Secret used to sign session cookies. CHANGE THIS in production.
SECRET_KEY=dev-secret-change-me

# SQLite database location (any SQLAlchemy URL works).
# Leave commented to use the project-anchored default (expense-system/expense.db),
# which keeps the seed script and the server pointed at the SAME file no matter
# which directory you launch from. Uncomment only to override.
# DATABASE_URL=sqlite:///./expense.db

# Where uploaded receipt images are stored (defaults to expense-system/uploads).
# UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# Default currency for new records.
DEFAULT_CURRENCY=CNY

# Auto-create demo accounts (admin/admin123, alice/alice123) on first startup
# when the database is empty. Set to false to disable (e.g. in production).
AUTO_SEED=true

# ------------------------------------------------------------------
# LLM provider (OpenAI-compatible Chat Completions API).
# Leave LLM_API_KEY empty to run in offline "mock" mode — the app
# still works, receipt fields just need to be entered manually and
# analysis falls back to built-in aggregations.
#
# Examples:
#   OpenAI      BASE_URL=https://api.openai.com/v1        MODEL=gpt-4o-mini       VISION=gpt-4o
#   DeepSeek    BASE_URL=https://api.deepseek.com/v1      MODEL=deepseek-chat     VISION=deepseek-chat
#   Qwen        BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  MODEL=qwen-plus  VISION=qwen-vl-plus
#   Moonshot    BASE_URL=https://api.moonshot.cn/v1       MODEL=moonshot-v1-8k    VISION=moonshot-v1-8k-vision-preview
#   Ollama      BASE_URL=http://localhost:11434/v1        MODEL=llama3.1          VISION=llama3.2-vision
# ------------------------------------------------------------------
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_VISION_MODEL=gpt-4o
